# Database
DATABASE_URL=postgresql://user:password@localhost:5432/betsys

# Bot wallet private key (used for oracle reporting, settlement, claim)
BOT_PRIVATE_KEY=

# JWT secret for session tokens (falls back to BOT_PRIVATE_KEY if not set)
JWT_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# OpenAI
OPENAI_API_KEY=

# CoinGecko
COINGECKO_API_KEY=

# Basescan API key (contract verification)
BASESCAN_API_KEY=

# X (Twitter) API credentials
X_API_BEARER_TOKEN=
X_API_ACCESS_TOKEN=
X_API_CONSUMER_KEY=
X_API_CONSUMER_SECRET=
X_API_ACCESS_TOKEN_SECRET=

# Uniswap Trading API key (https://hub.uniswap.org)
UNISWAP_API_KEY=

# Integrator fee injected into /api/uniswap/quote. Set both to enable.
# bps: 25 = 0.25%, max 250 (2.5%). Fee is paid in the output token (USDC).
UNISWAP_FEE_BPS=
UNISWAP_FEE_RECIPIENT=
