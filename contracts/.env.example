# Deployer private key (DO NOT commit real keys)
PRIVATE_KEY=0x

# Optional owner / bootstrap config for PriceOracleFactory deployment
PRICE_ORACLE_FACTORY_OWNER=0x0000000000000000000000000000000000000000
DEFAULT_ORACLE_REPORTER=0x0000000000000000000000000000000000000000
SEED_DEFAULT_ORACLES=true

# Token addresses (Base Sepolia testnet)
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Fee config (2.5% default)
FEE_BPS=250
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# Existing oracle addresses used when deploying BetFactory only
BTC_PRICE_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
LINK_PRICE_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000

# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
ARC_TESTNET_RPC_URL=

# USDC addresses per chain (Base Sepolia default above; override for other chains)
BASE_MAINNET_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
ARC_TESTNET_USDC_ADDRESS=

# Block explorer API keys for contract verification
BASESCAN_API_KEY=YOUR_KEY
ARC_EXPLORER_API_KEY=
