# WalletConnect project ID (get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Custom RPC endpoints (optional — falls back to wagmi's default public RPC)
VITE_BASE_RPC_URL=
VITE_BASE_SEPOLIA_RPC_URL=

# Uniswap integrator fee bps used for client-side output adjustment.
# Must match UNISWAP_FEE_BPS in the bot. When > 0, the quote target is grossed
# up so the user receives exactly the displayed USDC amount after the fee.
VITE_UNISWAP_FEE_BPS=
