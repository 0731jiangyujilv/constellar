# ───────────────────────────────────────────────────────
# Oracle swarm configuration
# Each oracle node reads the same .env — node-specific
# settings are selected via ORACLE_NODE at boot time.
# ───────────────────────────────────────────────────────

# Bot endpoint that receives heartbeats (POST /api/swarm/heartbeat)
BOT_HEARTBEAT_URL=http://localhost:3000/api/swarm/heartbeat

# Gemini (used by all oracles for summarize + verdict)
GEMINI_API_KEY=

# x402 mode:
#   mock — skip on-chain settlement, generate fake tx hashes (default for dev)
#   live — decode EIP-3009 payload, oracle submits transferWithAuthorization on Arc
X402_MODE=live
X402_FACILITATOR_URL=https://facilitator.x402.org
X402_NETWORK=arc-testnet

# USDC token on Arc testnet
# EIP-712 domain on Arc reports name="USDC" version="2" (differs from mainnet Circle "USD Coin")
USDC_ADDRESS=0x0000000000000000000000000000000000000000
USDC_NAME=USDC
USDC_VERSION=2

# Live mode: oracle-side wallet that submits transferWithAuthorization.
# Needs a tiny USDC balance for gas (Arc uses USDC as gas).
ORACLE_SETTLER_PRIVATE_KEY=

# Port allocation
PORT_TWITTER=4001
PORT_GOOGLE=4002
PORT_NEWS=4003
PORT_REDDIT=4004
PORT_YOUTUBE=4005

# Upstream data source credentials (all optional — oracles fall back to stub data)
X_BEARER_TOKEN=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
REDDIT_USER_AGENT=betsys-oracle/0.1
YOUTUBE_API_KEY=

# Wallet addresses that receive USDC per node (can be Circle Wallets)
WALLET_TWITTER=0x4a2c8b9f7e3d1a5c2b0f8e7d6a9c4b2f8f2c0000
WALLET_GOOGLE=0x9131ab73ef21d9c4f8b2a7e6d8c3f1a937ed0000
WALLET_NEWS=0x7dab42ef8c0a15b9d6e4f3c281bfa92c10400000
WALLET_REDDIT=0x5c92f1e84bd30a7c9f2e5b8d4a1c6f8e92730000
WALLET_YOUTUBE=0x3f08ac62d9b1e7f5c8a4b3d2f1e6c9a83a1b0000

# ERC-8004 OracleRegistry (populate AFTER running `npm run swarm:register` in bot)
ORACLE_REGISTRY_ADDRESS=
ARC_RPC_URL=https://arc-testnet.drpc.org
ARC_CHAIN_ID=5042002
AGENT_TOKEN_TWITTER=0
AGENT_TOKEN_GOOGLE=0
AGENT_TOKEN_NEWS=0
AGENT_TOKEN_REDDIT=0
AGENT_TOKEN_YOUTUBE=0
